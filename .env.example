GOOGLE_API_KEY=GET IT FROM GEMINI / GOOGLE AI STUDIO, NOT FROM GOOGLE CLOUD CONSOLE
OPENAI_API_KEY=GET IT FROM OPENAI, (OPTIONAL) IF ANY MODEL USED IN THE GRAPH REQUIRES OPENAI KEY JUST CONVERT IT TO USE GOOGLE KEY IN THE LLM CONFIG
GOOGLE_GENAI_USE_VERTEXAI=0


LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=GET IT FROM LANGSMITH
LANGSMITH_PROJECT=ANY NAME YOU LIKE, E.G. "MY TEST PROJECT"


TAVILY_API_KEY=GET IT FROM TAVILY

# Telegram Bot Token - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: Restrict bot access to specific user IDs (comma-separated)
# Get your user ID by messaging @userinfobot on Telegram
# ALLOWED_USER_IDS=123456789,987654321


# [OPTIONAL] ONLY used for chatwoot integration for gift recommendation agent.
CHATWOOT_BASE_URL=
CHATWOOT_ACCESS_TOKEN=